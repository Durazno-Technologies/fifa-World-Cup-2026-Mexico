---
import '../styles/global.css';
import { db } from '../lib/db';
import { sessions } from '../lib/db/schema';
import { eq } from 'drizzle-orm';

export const prerender = false;

// Si ya hay sesión, redirigir a /
const sessionToken = Astro.cookies.get('session')?.value;
if (sessionToken) {
  try {
    const [session] = await db
      .select({ user_id: sessions.user_id, expires_at: sessions.expires_at })
      .from(sessions)
      .where(eq(sessions.token, sessionToken))
      .limit(1);
    if (session && new Date(session.expires_at) > new Date()) {
      return Astro.redirect('/');
    }
  } catch {}
}
---

<!DOCTYPE html>
<html lang="es" class="antialiased text-gray-900 bg-gray-50 dark:bg-gray-950 dark:text-gray-50">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión — Quiniela Mundial 2026</title>
    <meta name="description" content="Inicia sesión en tu quiniela del Mundial 2026." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen flex flex-col items-center justify-center p-4">
    <main class="w-full max-w-sm">
      <div class="text-center mb-8">
        <img src="/logo.svg" alt="Durazno" class="w-20 h-20 mx-auto mb-4 drop-shadow-md" />
        <h1 class="text-3xl md:text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-dz-orange to-dz-green">
          Quiniela Mundial 2026
        </h1>
        <p class="text-gray-500 dark:text-gray-400 mt-2 text-sm">Ingresa con tu usuario y contraseña</p>
      </div>

      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-xl p-6 border border-gray-100 dark:border-gray-700">
        <form id="login-form" class="space-y-4">
          <div>
            <label for="username" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1">Usuario</label>
            <input type="text" id="username" name="username" required autocomplete="username" placeholder="Tu usuario" class="w-full px-4 py-3 rounded-xl bg-dz-light/50 dark:bg-black/50 border-2 border-gray-200 dark:border-gray-600 focus:ring-2 focus:ring-dz-orange focus:border-dz-orange outline-none font-medium" />
          </div>
          <div>
            <label for="password" class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1">Contraseña</label>
            <input type="password" id="password" name="password" required autocomplete="current-password" placeholder="••••••••" class="w-full px-4 py-3 rounded-xl bg-dz-light/50 dark:bg-black/50 border-2 border-gray-200 dark:border-gray-600 focus:ring-2 focus:ring-dz-orange focus:border-dz-orange outline-none font-medium" />
          </div>

          <div id="error-container" class="hidden">
            <p id="error-message" class="text-red-500 text-sm font-medium text-center"></p>
          </div>

          <button type="submit" id="btn-login" class="w-full px-6 py-3.5 bg-gradient-to-r from-dz-orange to-dz-green hover:opacity-90 text-white font-black rounded-xl shadow-lg transform transition active:scale-95 text-lg disabled:opacity-50 disabled:cursor-not-allowed">
            Ingresar
          </button>
        </form>
      </div>

      <footer class="mt-8 text-center text-xs text-gray-400 dark:text-gray-600">
        <div class="flex items-center justify-center gap-2">
          <img src="/logo.svg" alt="Durazno" class="w-4 h-4 opacity-60" />
          <span>Powered by Durazno Technologies</span>
        </div>
      </footer>
    </main>

    <script>
      const form = document.getElementById('login-form') as HTMLFormElement;
      const usernameInput = document.getElementById('username') as HTMLInputElement;
      const passwordInput = document.getElementById('password') as HTMLInputElement;
      const btnLogin = document.getElementById('btn-login') as HTMLButtonElement;
      const errorContainer = document.getElementById('error-container') as HTMLElement;
      const errorMessage = document.getElementById('error-message') as HTMLElement;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorContainer.classList.add('hidden');
        btnLogin.disabled = true;
        btnLogin.textContent = 'Ingresando...';

        try {
          const res = await fetch('/api/auth/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              username: usernameInput.value,
              password: passwordInput.value,
            }),
          });

          const data = await res.json();

          if (res.ok && data.ok) {
            window.location.href = '/';
          } else {
            errorMessage.textContent = data.error || 'Usuario o contraseña inválidos';
            errorContainer.classList.remove('hidden');
          }
        } catch {
          errorMessage.textContent = 'Error de conexión. Intenta de nuevo.';
          errorContainer.classList.remove('hidden');
        } finally {
          btnLogin.disabled = false;
          btnLogin.textContent = 'Ingresar';
        }
      });
    </script>
  </body>
</html>
