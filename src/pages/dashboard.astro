---
import '../styles/global.css';
import { db } from '../lib/db';
import { users, predictions } from '../lib/db/schema';
import { results } from '../lib/db/schema';
import { eq } from 'drizzle-orm';
import { scoreUserPredictions } from '../lib/scoring';
import type { MatchResult } from '../lib/scoring';

export const prerender = false;

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login');
}

// Cargar resultados reales de la DB
const dbResults = await db.select().from(results);
const realResults: MatchResult[] = dbResults.map(r => ({
  id: r.match_id,
  golesLocal: r.goles_local,
  golesVisita: r.goles_visita,
  video: r.video,
}));

// Obtener todos los usuarios que tienen al menos una predicción
const usersWithPredictions = await db
  .select({
    id: users.id,
    display_name: users.display_name,
    username: users.username,
  })
  .from(users)
  .innerJoin(predictions, eq(users.id, predictions.user_id))
  .groupBy(users.id, users.display_name, users.username);

// Cargar todas las predicciones de todos los usuarios
const allPredictions = await db
  .select({
    user_id: predictions.user_id,
    match_id: predictions.match_id,
    resultado: predictions.resultado,
    goles_local: predictions.goles_local,
    goles_visita: predictions.goles_visita,
  })
  .from(predictions);

// Calcular puntos por usuario
const scoresByUser = new Map<number, number>();
const userInfo = new Map<number, { display_name: string; username: string }>();

for (const u of usersWithPredictions) {
  userInfo.set(u.id, { display_name: u.display_name, username: u.username });

  const userPreds = allPredictions
    .filter(p => p.user_id === u.id)
    .map(p => ({
      matchId: p.match_id,
      resultado: p.resultado as 'L' | 'E' | 'V',
      golesLocal: p.goles_local,
      golesVisita: p.goles_visita,
    }));

  const totalScore = scoreUserPredictions(userPreds, realResults);
  scoresByUser.set(u.id, totalScore);
}

// Ordenar por puntos descendente
const rankings = Array.from(scoresByUser.entries())
  .sort((a, b) => b[1] - a[1])
  .map(([userId, score], index) => {
    const info = userInfo.get(userId)!;
    return {
      position: index + 1,
      username: info.username,
      display_name: info.display_name,
      score,
    };
  });
---

<!DOCTYPE html>
<html lang="es" class="antialiased text-gray-900 bg-gray-50 dark:bg-gray-950 dark:text-gray-50">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard — Quiniela Mundial 2026</title>
    <meta name="description" content="Leaderboard de la quiniela del Mundial 2026." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="w-full max-w-4xl mx-auto p-4 flex justify-between items-center">
      <div class="flex items-center gap-2">
        <span class="text-xl">⚽</span>
        <span class="font-black text-xl tracking-tight text-dz-dark dark:text-gray-100">FIFA World Cup <span class="text-dz-orange font-bold">2026</span></span>
      </div>
      <div class="flex items-center gap-3">
        <a href="/" class="text-sm font-semibold text-dz-orange hover:underline">Mi Quiniela</a>
        <span class="text-sm text-gray-500 dark:text-gray-400">{user!.display_name}</span>
        <button id="btn-logout" class="text-xs text-gray-400 hover:text-red-500 transition-colors cursor-pointer">Salir</button>
      </div>
    </header>

    <main class="flex-1 w-full max-w-4xl mx-auto p-4">
      <div class="text-center mb-8">
        <h1 class="text-3xl md:text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-dz-orange to-dz-green">
          Leaderboard
        </h1>
        <p class="text-gray-500 dark:text-gray-400 mt-2">Clasificación de todos los participantes</p>
      </div>

      {
        rankings.length === 0 ? (
          <div class="text-center py-12">
            <p class="text-gray-400 dark:text-gray-500 text-lg">No hay participantes todavía.</p>
            <p class="text-gray-400 dark:text-gray-500 text-sm mt-1">Las predicciones aparecerán aquí cuando los usuarios guarden su quiniela.</p>
          </div>
        ) : (
          <div class="space-y-3">
            {rankings.map((entry) => (
              <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4 border border-gray-100 dark:border-gray-700 flex items-center justify-between hover:shadow-md transition-shadow">
                <div class="flex items-center gap-4">
                  <span class={`w-8 h-8 rounded-full flex items-center justify-center text-sm font-black ${
                    entry.position === 1
                      ? 'bg-yellow-400 text-yellow-900'
                      : entry.position === 2
                      ? 'bg-gray-300 text-gray-700'
                      : entry.position === 3
                      ? 'bg-amber-600 text-white'
                      : 'bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400'
                  }`}>
                    {entry.position}
                  </span>
                  <div>
                    <a href={`/quiniela/${entry.username}`} class="font-bold text-dz-dark dark:text-gray-100 hover:text-dz-orange dark:hover:text-dz-orange transition-colors">
                      {entry.display_name}
                    </a>
                  </div>
                </div>
                <div class="flex items-center gap-2">
                  <span class="text-2xl font-black text-dz-orange">{entry.score}</span>
                  <span class="text-xs text-gray-400">pts</span>
                </div>
              </div>
            ))}
          </div>
        )
      }
    </main>

    <!-- Footer -->
    <footer class="w-full py-4 text-center text-xs text-gray-400 dark:text-gray-600">
      <div class="flex items-center justify-center gap-2">
        <img src="/logo.svg" alt="Durazno" class="w-4 h-4 opacity-60" />
        <span>Powered by Durazno Technologies</span>
      </div>
    </footer>

    <script>
      const btnLogout = document.getElementById('btn-logout');
      if (btnLogout) {
        btnLogout.addEventListener('click', async () => {
          await fetch('/api/auth/logout', { method: 'POST' });
          window.location.href = '/login';
        });
      }
    </script>
  </body>
</html>
