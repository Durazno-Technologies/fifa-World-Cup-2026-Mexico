---
import '../styles/global.css';
import Layout from '../components/Layout.astro';
import { db } from '../lib/db';
import { users, predictions } from '../lib/db/schema';
import { results } from '../lib/db/schema';
import { eq } from 'drizzle-orm';
import { scoreUserPredictions } from '../lib/scoring';
import type { MatchResult } from '../lib/scoring';
import { getNextMatches, getPredictionsForNextMatches, extractFlag, setTestNowSec } from '../lib/next-match';

export const prerender = false;

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login');
}

// ================================================================
// MODO TEST: Simular la 3ra fecha con 2 partidos simultáneos
// Descomenta la línea de abajo para previsualizar el stacking vertical.
// (Los 2 partidos del Grupo A: Rep. Checa vs México Y Sudáfrica vs Corea
//  comienzan ambos el 24 de junio 19:00 CDMX, kickoff=1782349200)
// ================================================================
// setTestNowSec(1782400000); // 20 min antes del kickoff simultáneo
// ================================================================

// Cargar resultados reales de la DB
const dbResults = await db.select().from(results);
const realResults: MatchResult[] = dbResults.map(r => ({
  id: r.match_id,
  golesLocal: r.goles_local,
  golesVisita: r.goles_visita,
  video: r.video,
}));

// Obtener todos los usuarios que tienen al menos una predicción
const usersWithPredictions = await db
  .select({
    id: users.id,
    display_name: users.display_name,
    username: users.username,
  })
  .from(users)
  .innerJoin(predictions, eq(users.id, predictions.user_id))
  .groupBy(users.id, users.display_name, users.username);

// Cargar todas las predicciones de todos los usuarios
const allPredictions = await db
  .select({
    user_id: predictions.user_id,
    match_id: predictions.match_id,
    resultado: predictions.resultado,
    goles_local: predictions.goles_local,
    goles_visita: predictions.goles_visita,
  })
  .from(predictions);

// Calcular puntos por usuario
const scoresByUser = new Map<number, number>();
const userInfo = new Map<number, { display_name: string; username: string }>();

// Agrupar predicciones por usuario para next-match lookup
const predictionsByUser = new Map<number, Array<{ match_id: number; goles_local: number; goles_visita: number }>>();
for (const p of allPredictions) {
  if (!predictionsByUser.has(p.user_id)) {
    predictionsByUser.set(p.user_id, []);
  }
  predictionsByUser.get(p.user_id)!.push({
    match_id: p.match_id,
    goles_local: p.goles_local,
    goles_visita: p.goles_visita,
  });
}

// Calcular next match info (SSR-safe, usa tiempo del servidor CDMX)
const nextMatchInfo = getNextMatches();

// Pre-calcular predicciones de next match para cada usuario
const nextMatchPredsByUser = new Map<number, ReturnType<typeof getPredictionsForNextMatches>>();
for (const u of usersWithPredictions) {
  const userPreds = predictionsByUser.get(u.id) ?? [];
  nextMatchPredsByUser.set(u.id, getPredictionsForNextMatches(userPreds));
}

for (const u of usersWithPredictions) {
  userInfo.set(u.id, { display_name: u.display_name, username: u.username });

  const userPreds = allPredictions
    .filter(p => p.user_id === u.id)
    .map(p => ({
      matchId: p.match_id,
      resultado: p.resultado as 'L' | 'E' | 'V',
      golesLocal: p.goles_local,
      golesVisita: p.goles_visita,
    }));

  const totalScore = scoreUserPredictions(userPreds, realResults);
  scoresByUser.set(u.id, totalScore);
}

// Ordenar por puntos descendente
const rankings = Array.from(scoresByUser.entries())
  .sort((a, b) => b[1] - a[1])
  .map(([userId, score], index) => {
    const info = userInfo.get(userId)!;
    return {
      position: index + 1,
      username: info.username,
      display_name: info.display_name,
      score,
      nextPreds: nextMatchPredsByUser.get(userId) ?? [],
    };
  });
---

<Layout title="Dashboard — Quiniela Mundial 2026" description="Leaderboard de la quiniela del Mundial 2026.">
  <!-- Header -->
  <header class="w-full max-w-4xl mx-auto p-4 flex justify-between items-center">
    <div class="flex items-center gap-2">
      <span class="text-xl">⚽</span>
      <span class="font-black text-xl tracking-tight text-dz-dark dark:text-gray-100">FIFA World Cup <span class="text-dz-orange font-bold">2026</span></span>
    </div>
    <div class="flex items-center gap-3">
      <span class="text-sm text-gray-500 dark:text-gray-400">{user!.display_name}</span>
      <button id="btn-logout" class="text-xs text-gray-400 hover:text-red-500 transition-colors cursor-pointer">Salir</button>
    </div>
  </header>

  <main class="flex-1 w-full max-w-4xl mx-auto p-4">
    <div class="text-center mb-6">
      <h1 class="text-3xl md:text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-dz-orange to-dz-green">
        Leaderboard
      </h1>
      <p class="text-gray-500 dark:text-gray-400 mt-2">Clasificación de todos los participantes</p>
    </div>

    <!-- Next Match Banner -->
    {
      nextMatchInfo.hasNext && (
        <div class="mb-4 bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-950/30 dark:to-indigo-950/30 rounded-xl border border-blue-100 dark:border-blue-900/50 p-3 text-center">
          <span class="text-[11px] font-semibold text-blue-600 dark:text-blue-400 tracking-wide uppercase">
            ⏳ {nextMatchInfo.label}
          </span>
        </div>
      )
    }

    {
      rankings.length === 0 ? (
        <div class="text-center py-12">
          <p class="text-gray-400 dark:text-gray-500 text-lg">No hay participantes todavía.</p>
          <p class="text-gray-400 dark:text-gray-500 text-sm mt-1">Las predicciones aparecerán aquí cuando los usuarios guarden su quiniela.</p>
        </div>
      ) : (
        <div class="space-y-2">
          {rankings.map((entry) => (
            <a href={`/quiniela/${entry.username}`} class="block bg-white dark:bg-gray-800 rounded-xl shadow-sm p-3 md:p-4 border border-gray-100 dark:border-gray-700 hover:shadow-md hover:ring-2 hover:ring-dz-orange/40 transition-all cursor-pointer">
              <div class="flex items-center justify-between gap-2">
                <!-- LEFT SIDE: Position + Display name -->
                <div class="flex items-center gap-2 md:gap-3 min-w-0 shrink">
                  <!-- Position -->
                  <span class={`w-7 h-7 md:w-8 md:h-8 rounded-full flex items-center justify-center text-xs md:text-sm font-black shrink-0 ${
                    entry.position === 1
                      ? 'bg-yellow-400 text-yellow-900'
                      : entry.position === 2
                      ? 'bg-gray-300 text-gray-700'
                      : entry.position === 3
                      ? 'bg-amber-600 text-white'
                      : 'bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400'
                  }`}>
                    {entry.position}
                  </span>

                  <!-- Display name (truncates if needed) -->
                  <span class="font-bold text-sm md:text-base text-dz-dark dark:text-gray-100 truncate">
                    {entry.display_name}
                  </span>
                </div>

                <!-- RIGHT SIDE: Next Match predictions + Points (grouped together) -->
                <div class="flex items-center shrink-0">
                  <!-- Next Match Prediction Column (user-specific scores) -->
                  {
                    entry.nextPreds.length > 0 && (
                      <div class="flex flex-col items-end gap-0.5 mr-4 md:mr-6">
                        {entry.nextPreds.map((pred) => (
                          <div class="flex items-center gap-1 text-xs md:text-sm font-medium leading-tight whitespace-nowrap">
                            <span class="opacity-60">{extractFlag(pred.local)}</span>
                            <span class="font-black text-dz-dark dark:text-gray-100">{pred.golesLocal}</span>
                            <span class="text-gray-300 dark:text-gray-500">-</span>
                            <span class="font-black text-dz-dark dark:text-gray-100">{pred.golesVisita}</span>
                            <span class="opacity-60">{extractFlag(pred.visita)}</span>
                          </div>
                        ))}
                      </div>
                    )
                  }

                  <!-- Points -->
                  <div class="flex items-center gap-1">
                    <span class="text-xl md:text-2xl font-black text-dz-orange">{entry.score}</span>
                    <span class="text-[10px] md:text-xs text-gray-400">pts</span>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      )
    }
  </main>

  <!-- Footer -->
  <footer class="w-full py-4 text-center text-xs text-gray-400 dark:text-gray-600">
    <div class="flex items-center justify-center gap-2">
      <img src="/logo.svg" alt="Durazno" class="w-4 h-4 opacity-60" />
      <span>Powered by Durazno Technologies</span>
    </div>
  </footer>

  <script>
    const btnLogout = document.getElementById('btn-logout');
    if (btnLogout) {
      btnLogout.addEventListener('click', async () => {
        await fetch('/api/auth/logout', { method: 'POST' });
        window.location.href = '/login';
      });
    }
  </script>
</Layout>