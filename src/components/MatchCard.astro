---
import type { Match } from '../data/matches';
export interface Props {
  match: Match;
}
const { match } = Astro.props;
---
<div class="match-card bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4 flex flex-col gap-3 border border-gray-100 dark:border-gray-700 transition-all hover:shadow-md" data-match-id={match.id}>
  <div class="text-xs text-center text-gray-500 font-semibold tracking-wider uppercase">
    Grupo {match.group} • {match.dateStr}
  </div>
  
  <div class="flex items-center justify-between gap-2">
    <!-- Local -->
    <div class="flex-1 text-right flex flex-col">
      <span class="font-bold text-gray-800 dark:text-gray-100">{match.local}</span>
    </div>
    
    <!-- Score inputs -->
    <div class="flex items-center gap-2 px-2">
      <input type="number" min="0" max="99" class="w-12 h-12 text-center text-xl font-bold bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none score-input-local" placeholder="-" />
      <span class="text-gray-400 font-bold">-</span>
      <input type="number" min="0" max="99" class="w-12 h-12 text-center text-xl font-bold bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 outline-none score-input-visita" placeholder="-" />
    </div>

    <!-- Visita -->
    <div class="flex-1 text-left flex flex-col">
      <span class="font-bold text-gray-800 dark:text-gray-100">{match.visita}</span>
    </div>
  </div>
  
  <!-- Result indicator -->
  <div class="text-center mt-1 h-6">
    <span class="inline-block px-3 py-1 rounded-full text-[10px] font-bold transition-colors duration-200 bg-gray-100 text-gray-400 result-badge opacity-0">...</span>
  </div>
</div>
