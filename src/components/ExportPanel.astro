<div id="export-view" class="w-full max-w-md mx-auto hidden flex-col items-center justify-center p-6 bg-white dark:bg-gray-800 rounded-3xl shadow-2xl border border-gray-100 dark:border-gray-700 mt-10">
  <h2 class="text-2xl font-bold text-center mb-6 text-gray-800 dark:text-gray-100">¡Tu Quiniela está lista!</h2>
  
  <div id="qr-container" class="bg-white p-4 rounded-2xl shadow-inner mb-8 flex justify-center items-center w-[300px] h-[300px] mx-auto overflow-hidden">
    <!-- QR gets injected here -->
  </div>
  
  <div class="w-full flex flex-col gap-3">
    <button id="btn-share-wa" class="w-full flex items-center justify-center gap-2 bg-[#25D366] hover:bg-[#1DA851] text-white font-bold py-3 px-4 rounded-xl transition-colors">
