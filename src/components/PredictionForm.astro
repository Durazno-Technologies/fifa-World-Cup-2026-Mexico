---
import { matches } from '../data/matches';
import MatchCard from './MatchCard.astro';
---

<div id="prediction-view" class="w-full max-w-5xl mx-auto pb-28">
  <div class="mb-6 text-center pt-8">
    <img src="/logo.svg" alt="Durazno" class="w-16 h-16 mx-auto mb-4 drop-shadow-md" />
    <h1 id="prediction-title" class="text-4xl md:text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-dz-orange to-dz-green mb-2">Mi Quiniela</h1>
    <p class="text-gray-600 dark:text-gray-400 font-medium">Llena tus pronósticos para la fase de grupos</p>

    <div id="countdown-container" class="mt-4 inline-flex items-center justify-center font-bold px-5 py-2.5 rounded-full text-sm shadow-sm transition-colors border">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      Cierra en: <span id="countdown-timer" class="ml-2 tabular-nums">Calculando...</span>
    </div>
  </div>

  <form id="quiniela-form" class="space-y-6 px-2 md:px-0 hidden">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-4">
      {matches.map(m => (
        <MatchCard match={m} />
      ))}
    </div>

    <div class="fixed bottom-0 left-0 right-0 z-50 bg-white/90 dark:bg-dz-dark/95 backdrop-blur-xl border-t border-gray-200 dark:border-gray-800 p-4 shadow-[0_-10px_40px_rgba(0,0,0,0.1)]">
      <div class="max-w-4xl mx-auto flex items-center justify-between gap-4 relative">
          <!-- button type="button" id="btn-dev-fill" class="absolute -top-14 right-2 bg-yellow-400 hover:bg-yellow-500 text-yellow-900 text-xs font-black px-4 py-2 rounded-full shadow-lg cursor-pointer flex items-center gap-1 transition-transform active:scale-95 z-50 hidden">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 012 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"></path></svg>
            DEV: Aleatorio
          </button -->
      </div>
    </div>
  </form>
</div>