---
---
<div id="readonly-view" class="w-full max-w-4xl mx-auto hidden pb-12 pt-8">
  <!-- Sticky score bar -->
  <div class="sticky top-0 z-40 bg-white/90 dark:bg-gray-900/90 backdrop-blur-md py-3 px-5 rounded-b-2xl shadow-md border border-gray-100 dark:border-gray-700 mb-6 flex items-center justify-between">
    <span class="text-sm font-semibold text-gray-600 dark:text-gray-300">Puntos acumulados</span>
    <div class="flex items-center gap-2">
      <span class="text-xs text-gray-400">⚽</span>
      <span id="readonly-score" class="text-3xl font-black text-dz-orange">0</span>
      <span class="text-xs text-gray-400">pts</span>
    </div>
  </div>

  <div class="mb-8 text-center bg-white/50 dark:bg-gray-800/50 backdrop-blur-md py-6 px-4 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-700">
    <h1 class="text-3xl md:text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-400 mb-2">
      Quiniela de <span id="readonly-name" class="text-gray-800 dark:text-gray-100"></span>
    </h1>
    <p class="text-gray-600 dark:text-gray-400">Pronósticos de la primera fase</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="readonly-matches">
    <!-- Populated by JS -->
  </div>

  <div class="mt-12 text-center">
    <a href="/" id="btn-create-own" class="inline-block px-8 py-4 bg-gradient-to-r from-emerald-500 to-teal-500 hover:from-emerald-600 hover:to-teal-600 text-white font-bold rounded-xl shadow-lg transform transition active:scale-95 text-lg">
      ¡Crea tu propia quiniela!
    </a>
  </div>
</div>

<template id="readonly-match-template">
  <div class="readonly-card relative bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4 flex flex-col gap-3 border border-gray-100 dark:border-gray-700 transition-all">
    <!-- Points badge - positioned to overflow top-right -->
    <span class="absolute -top-2 -right-2 inline-flex items-center justify-center w-8 h-8 rounded-full text-xs font-black points-badge z-10"></span>
    <div class="text-xs text-center text-gray-500 font-semibold tracking-wider uppercase group-date-label">
      Grupo X
    </div>

    <!-- Sección: Apuesta del usuario -->
    <div class="flex flex-col gap-2">
      <div class="flex items-center justify-between gap-2">
        <div class="flex-1 text-right flex flex-col">
          <span class="font-bold text-gray-800 dark:text-gray-100 local-name text-sm md:text-base transition-all">Local</span>
        </div>
        <div class="flex items-center justify-center gap-3 px-4 bg-gray-50 dark:bg-gray-900 rounded-lg py-2 border border-gray-100 dark:border-gray-700 shadow-inner min-w-[100px]">
          <span class="text-xl font-black text-gray-800 dark:text-gray-100 local-score">0</span>
          <span class="text-gray-300 dark:text-gray-600">-</span>
          <span class="text-xl font-black text-gray-800 dark:text-gray-100 visita-score">0</span>
        </div>
        <div class="flex-1 text-left flex flex-col">
          <span class="font-bold text-gray-800 dark:text-gray-100 visita-name text-sm md:text-base transition-all">Visita</span>
        </div>
      </div>
      <div class="text-center h-6 flex justify-center items-center">
        <span class="inline-block px-3 py-1 rounded-full text-[10px] font-bold result-badge text-gray-600 bg-gray-100 dark:bg-gray-700 dark:text-gray-300">Resultado</span>
      </div>
    </div>

    <!-- Separador sutil -->
    <div class="real-result-section hidden">
      <div class="border-t border-dashed border-gray-200 dark:border-gray-600 my-1"></div>

      <!-- Sección: Resultado Real -->
      <div class="flex flex-col gap-2">
        <div class="text-center">
          <span class="text-[10px] font-semibold text-gray-400 dark:text-gray-500 tracking-wider uppercase">Resultado Real</span>
        </div>
        <div class="flex items-center justify-center gap-3">
          <span class="text-lg font-black real-local-score text-gray-800 dark:text-gray-100">0</span>
          <span class="text-gray-300 dark:text-gray-600">-</span>
          <span class="text-lg font-black real-visita-score text-gray-800 dark:text-gray-100">0</span>
        </div>
        <!-- Video thumbnail con link -->
        <a class="video-link hidden group/video relative block rounded-lg overflow-hidden border border-gray-100 dark:border-gray-700 shadow-sm hover:shadow-md transition-all hover:scale-[1.02] active:scale-[0.98]" href="#" target="_blank" rel="noopener noreferrer">
          <img class="video-thumbnail w-full aspect-video object-cover bg-gray-100 dark:bg-gray-900" src="" alt="Resumen del partido" loading="lazy" />
          <!-- Play overlay -->
          <div class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover/video:bg-black/30 transition-colors">
            <div class="w-12 h-12 rounded-full bg-red-600 flex items-center justify-center shadow-lg group-hover/video:scale-110 transition-transform">
              <svg class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 to-transparent px-3 py-2">
            <span class="text-white text-[10px] font-semibold flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M21.582 6.186a2.506 2.506 0 0 0-1.768-1.768C18.254 4 12 4 12 4s-6.254 0-7.814.418c-.86.23-1.538.908-1.768 1.768C2 7.746 2 12 2 12s0 4.254.418 5.814c.23.86.908 1.538 1.768 1.768C5.746 20 12 20 12 20s6.254 0 7.814-.418a2.506 2.506 0 0 0 1.768-1.768C22 16.254 22 12 22 12s0-4.254-.418-5.814z"/><path d="M10 15.464V8.536L16 12z" fill="white"/></svg>
              Ver resumen
            </span>
          </div>
        </a>
      </div>
    </div>
  </div>
</template>
