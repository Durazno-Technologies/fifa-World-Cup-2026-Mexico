---
---
<div id="readonly-view" class="w-full max-w-4xl mx-auto hidden pb-12 pt-8">
  <div class="mb-8 text-center bg-white/50 dark:bg-gray-800/50 backdrop-blur-md py-6 px-4 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-700">
    <h1 class="text-3xl md:text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-400 mb-2">
      Quiniela de <span id="readonly-name" class="text-gray-800 dark:text-gray-100"></span>
    </h1>
    <p class="text-gray-600 dark:text-gray-400">Pronósticos de la primera fase</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="readonly-matches">
    <!-- Populated by JS -->
  </div>

  <div class="mt-12 text-center">
    <a href="/" id="btn-create-own" class="inline-block px-8 py-4 bg-gradient-to-r from-emerald-500 to-teal-500 hover:from-emerald-600 hover:to-teal-600 text-white font-bold rounded-xl shadow-lg transform transition active:scale-95 text-lg">
      ¡Crea tu propia quiniela!
    </a>
  </div>
</div>

<template id="readonly-match-template">
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4 flex flex-col gap-3 border border-gray-100 dark:border-gray-700">
    <div class="text-xs text-center text-gray-500 font-semibold tracking-wider uppercase group-date-label">
      Grupo X
    </div>
    <div class="flex items-center justify-between gap-2">
      <div class="flex-1 text-right flex flex-col">
        <span class="font-bold text-gray-800 dark:text-gray-100 local-name text-sm md:text-base">Local</span>
      </div>
      <div class="flex items-center gap-3 px-4 bg-gray-50 dark:bg-gray-900 rounded-lg py-2 border border-gray-100 dark:border-gray-700 shadow-inner">
        <span class="text-xl font-black text-gray-800 dark:text-gray-100 local-score">0</span>
        <span class="text-gray-300 dark:text-gray-600">-</span>
        <span class="text-xl font-black text-gray-800 dark:text-gray-100 visita-score">0</span>
      </div>
      <div class="flex-1 text-left flex flex-col">
        <span class="font-bold text-gray-800 dark:text-gray-100 visita-name text-sm md:text-base">Visita</span>
      </div>
    </div>
    <div class="text-center mt-1 h-6 flex justify-center items-center">
      <span class="inline-block px-3 py-1 rounded-full text-[10px] font-bold result-badge text-gray-600 bg-gray-100 dark:bg-gray-700 dark:text-gray-300">Resultado</span>
    </div>
  </div>
</template>
